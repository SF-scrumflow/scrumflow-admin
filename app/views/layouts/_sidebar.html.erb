<aside class="w-64 bg-slate-900 border-r border-slate-800 flex-shrink-0 overflow-y-auto">
  <!-- Logo -->
  <div class="p-6 border-b border-slate-800">
    <h1 class="text-xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">
      Scrumflow
    </h1>
    <p class="text-xs text-slate-400 mt-1">Admin Panel</p>
  </div>

  <!-- Menu Items -->
  <nav class="p-4 space-y-2">
    <!-- Dashboard -->
    <a href="<%= admin_root_path %>" class="sidebar-item">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 11l4-4m-9-2l7-4 7 4" />
      </svg>
      <span>Dashboard</span>
    </a>

    <!-- Empresas -->
    <a href="<%= admin_enterprises_path %>" class="sidebar-item">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" />
      </svg>
      <span>Empresas</span>
    </a>

    <!-- Usuários -->
    <a href="<%= admin_users_path %>" class="sidebar-item">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-4-4h-1M9 20H4v-2a4 4 0 014-4h1m0-4a4 4 0 100-8 4 4 0 000 8zm8 0a4 4 0 100-8 4 4 0 000 8z" />
      </svg>
      <span>Usuários</span>
    </a>

    <!-- Projetos -->
    <a href="<%= admin_projects_path %>" class="sidebar-item">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
      </svg>
      <span>Projetos</span>
    </a>

    <!-- Assinaturas -->
    <a href="<%= admin_subscriptions_path %>" class="sidebar-item">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>Assinaturas</span>
    </a>

    <!-- Logs -->
    <a href="<%= admin_admin_logs_path %>" class="sidebar-item">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <span>Logs</span>
    </a>

  </nav>

  <!-- Divider -->
  <div class="border-t border-slate-800 my-4"></div>

  <!-- User Section -->
  <div class="p-4">
    <div class="flex items-center space-x-3 mb-4">
      <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-cyan-400 rounded-full flex items-center justify-center text-slate-900 font-bold">
        <%= current_admin.email.first.upcase %>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-100"><%= current_admin.email %></p>
        <p class="text-xs text-slate-400">Admin</p>
      </div>
    </div>
    <%= button_to "Logout", destroy_admin_session_path, method: :delete, class: "w-full px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-100 rounded-lg transition text-sm font-medium cursor-pointer" %>
  </div>
</aside>
