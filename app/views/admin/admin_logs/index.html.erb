<!-- Header -->
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold text-slate-50">Logs de Administrador</h1>
    <p class="text-slate-400 mt-1">Histórico de ações dos administradores</p>
  </div>
</div>

<!-- Search -->
<div class="flex gap-4 mb-6">
  <%= form_with url: admin_admin_logs_path, method: :get, local: true, class: "flex-1" do |f| %>
    <%= f.text_field :search, placeholder: "Buscar ação...", class: "input-field w-full", value: params[:search] %>
  <% end %>
</div>

<!-- Table -->
<div class="card overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-slate-700">
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Administrador</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Ação</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Tipo de Recurso</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">ID do Recurso</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Data</th>
        </tr>
      </thead>
      <tbody>
        <% @admin_logs.each do |log| %>
          <tr class="table-row">
            <td class="px-6 py-4 font-medium text-slate-50"><%= log.admin_email %></td>
            <td class="px-6 py-4 text-slate-300"><%= log.action %></td>
            <td class="px-6 py-4 text-slate-300"><%= log.resource_type %></td>
            <td class="px-6 py-4 text-slate-300"><%= log.resource_id %></td>
            <td class="px-6 py-4 text-slate-300 text-sm"><%= log.created_at.strftime("%d/%m/%Y %H:%M:%S") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<div class="mt-6 flex justify-center">
  <%= paginate @admin_logs %>
</div>
