<!-- Dashboard Header -->
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold text-slate-50">Dashboard</h1>
    <p class="text-slate-400 mt-1">Visão geral do sistema</p>
  </div>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- Total Enterprises -->
  <div class="card">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-slate-400 text-sm font-medium">Total de Empresas</p>
        <p class="text-3xl font-bold text-slate-50 mt-2"><%= @total_enterprises %></p>
        <p class="text-emerald-400 text-sm mt-2">
          <span class="font-semibold"><%= @active_enterprises || "N/A" %></span> ativas
        </p>
      </div>
      <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Total Subscriptions -->
  <div class="card">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-slate-400 text-sm font-medium">Assinaturas</p>
        <p class="text-3xl font-bold text-slate-50 mt-2"><%= @total_subscriptions %></p>
        <p class="text-emerald-400 text-sm mt-2">
          <span class="font-semibold"><%= @active_subscriptions || "N/A" %></span> ativas
        </p>
      </div>
      <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Users -->
  <div class="card">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-slate-400 text-sm font-medium">Usuários</p>
        <p class="text-3xl font-bold text-slate-50 mt-2"><%= @total_users %></p>
        <p class="text-emerald-400 text-sm mt-2">Registrados em empresas</p>
      </div>
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Projects -->
  <div class="card">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-slate-400 text-sm font-medium">Projetos</p>
        <p class="text-3xl font-bold text-slate-50 mt-2"><%= @total_projects %></p>
        <p class="text-emerald-400 text-sm mt-2">Registrados em empresas</p>
      </div>
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-green-500 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>
  </div>
</div>

<!-- Recent Activity -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Recent Enterprises -->
  <div class="lg:col-span-2 card">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-slate-50">Empresas Recentes</h2>
      <%= link_to "Ver Tudo", admin_enterprises_path, class: "text-cyan-400 hover:text-cyan-300 text-sm font-medium transition" %>
    </div>
    <div class="space-y-3">
      <% @recent_enterprises.each do |enterprise| %>
        <div class="flex items-center justify-between p-3 bg-slate-700/30 rounded-lg hover:bg-slate-700/50 transition">
          <div>
            <p class="font-medium text-slate-50"><%= enterprise.display_name %></p>
            <% if enterprise.has_attribute?(:created_at) && enterprise.created_at.present? %>
              <p class="text-sm text-slate-400">Criada <%= time_ago_in_words(enterprise.created_at) %> atrás</p>
            <% end %>
          </div>
          <div class="flex items-center space-x-3">
            <% if enterprise.active_status.present? %>
              <span class="<%= enterprise.active_badge %> badge"><%= enterprise.active_status %></span>
            <% end %>
            <%= link_to "Ver", admin_enterprise_path(enterprise), class: "text-cyan-400 hover:text-cyan-300 text-sm transition" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Logs -->
  <div class="card">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-slate-50">Atividade Recente</h2>
      <%= link_to "Mais", admin_admin_logs_path, class: "text-cyan-400 hover:text-cyan-300 text-sm font-medium transition" %>
    </div>
    <div class="space-y-3 max-h-96 overflow-y-auto">
      <% @recent_logs.each do |log| %>
        <div class="text-sm p-2 hover:bg-slate-700/30 rounded transition">
          <p class="text-slate-300">
            <span class="font-semibold"><%= log.admin_email.to_s.split('@').first %></span>
            <span class="text-slate-500"><%= log.action %></span>
          </p>
          <p class="text-xs text-slate-500 mt-1"><%= time_ago_in_words(log.created_at) %> atrás</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
