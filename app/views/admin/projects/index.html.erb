<!-- Header -->
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold text-slate-50">Projetos</h1>
    <p class="text-slate-400 mt-1">Consultar projetos reais do Scrumflow</p>
  </div>
</div>

<!-- Search -->
<div class="flex gap-4 mb-6">
  <%= form_with url: admin_projects_path, method: :get, local: true, class: "flex-1" do |f| %>
    <%= f.text_field :search, placeholder: "Buscar projeto...", class: "input-field w-full", value: params[:search] %>
  <% end %>
</div>

<!-- Table -->
<div class="card overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-slate-700">
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Nome</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Empresa</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Data</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr class="table-row">
            <td class="px-6 py-4 font-medium text-slate-50"><%= project.display_name %></td>
            <td class="px-6 py-4 text-slate-300"><%= project.has_attribute?(:enterprise_id) ? project.enterprise&.display_name || "N/A" : "N/A" %></td>
            <td class="px-6 py-4 text-slate-300 text-sm"><%= project.attribute_value(:created_at)&.strftime("%d/%m/%Y") || "N/A" %></td>
            <td class="px-6 py-4">
              <%= link_to "Ver", admin_project_path(project), class: "px-3 py-1 bg-slate-700 hover:bg-slate-600 text-slate-200 rounded text-sm transition" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<div class="mt-6 flex justify-center">
  <%= paginate @projects %>
</div>
